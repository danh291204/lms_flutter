generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model baihoc {
  idBaiHoc   Int        @id @default(autoincrement())
  idKhoaHoc  Int
  tenBaiHoc  String
  videoUrl   String?
  taiLieuUrl String?
  thuTu      Int?
  khoahoc    khoahoc    @relation(fields: [idKhoaHoc], references: [idKhoaHoc], onDelete: Cascade)
  progress   progress[]

  @@index([idKhoaHoc])
}

model dangky_khoahoc {
  idDangKy    Int       @id @default(autoincrement())
  idNguoiDung Int
  idKhoaHoc   Int
  ngayDangKy  DateTime? @default(now())
  khoahoc     khoahoc   @relation(fields: [idKhoaHoc], references: [idKhoaHoc])
  nguoidung   nguoidung @relation(fields: [idNguoiDung], references: [idNguoiDung])

  @@unique([idNguoiDung, idKhoaHoc])
  @@index([idKhoaHoc])
  @@index([idNguoiDung])
}

model khoahoc {
  idKhoaHoc      Int              @id @default(autoincrement())
  tenKhoaHoc     String
  code           String           @unique
  moTa           String?
  danhMuc        String?
  trangThai      Boolean
  idGiangVien    Int?
  ngayTao        DateTime?        @default(now())
  baihoc         baihoc[]
  dangky_khoahoc dangky_khoahoc[]
  nguoidung      nguoidung?       @relation(fields: [idGiangVien], references: [idNguoiDung])
  progress       progress[]
  quizzes        quizzes[]

  @@index([idGiangVien])
}

model nguoidung {
  idNguoiDung    Int               @id @default(autoincrement())
  hoTen          String
  taiKhoan       String            @unique
  matKhau        String
  trangThai      Boolean
  email          String
  vaiTro         nguoidung_vaiTro? @default(hocvien)
  dangky_khoahoc dangky_khoahoc[]
  khoahoc        khoahoc[]
  progress       progress[]
  quiz_results   quiz_results[]
}

model progress {
  idProgress  Int                 @id @default(autoincrement())
  idNguoiDung Int
  idKhoaHoc   Int
  idBaiHoc    Int
  trangThai   progress_trangThai? @default(chua_hoc)
  thoiGianHoc Int?                @default(0)
  baihoc      baihoc              @relation(fields: [idBaiHoc], references: [idBaiHoc], onDelete: Cascade)
  khoahoc     khoahoc             @relation(fields: [idKhoaHoc], references: [idKhoaHoc], onDelete: Cascade)
  nguoidung   nguoidung           @relation(fields: [idNguoiDung], references: [idNguoiDung], onDelete: Cascade)

  @@index([idBaiHoc])
  @@index([idKhoaHoc])
  @@index([idNguoiDung])
}

model quiz_questions {
  idCauHoi   Int      @id @default(autoincrement())
  idQuiz     Int
  cauHoi     String
  dapAnDung  String?
  diemCauHoi Decimal? @default(1.00)
  quizzes    quizzes  @relation(fields: [idQuiz], references: [idQuiz], onDelete: Cascade)

  @@index([idQuiz])
}

model quiz_results {
  idKetQua       Int       @id @default(autoincrement())
  idNguoiDung    Int
  idQuiz         Int?
  diemSo         Decimal?
  thoiGianLamBai Int?
  ngayLamBai     DateTime? @default(now())
  nguoidung      nguoidung @relation(fields: [idNguoiDung], references: [idNguoiDung], onDelete: Cascade)
  quizzes        quizzes?  @relation(fields: [idQuiz], references: [idQuiz])

  @@index([idNguoiDung])
  @@index([idQuiz])
}

model quizzes {
  idQuiz         Int              @id @default(autoincrement())
  idKhoaHoc      Int
  tenQuiz        String
  thoiGianLamBai Int?
  quiz_questions quiz_questions[]
  quiz_results   quiz_results[]
  khoahoc        khoahoc          @relation(fields: [idKhoaHoc], references: [idKhoaHoc], onDelete: Cascade)

  @@index([idKhoaHoc])
}

enum nguoidung_vaiTro {
  hocvien
  giangvien
  admin
}

enum progress_trangThai {
  chua_hoc
  dang_hoc
  hoan_thanh
}
